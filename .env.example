# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# OpenAI Whisper (або AssemblyAI — вибери одне)
OPENAI_API_KEY=your_openai_api_key
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Сховище відео/обкладинок — Cloudflare R2 (рекомендовано, безкоштовний egress) або AWS S3
# R2: Cloudflare dashboard > R2 > бакет > Manage API Tokens > Create API Token
S3_BUCKET=your_bucket_name
S3_REGION=auto
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Публічний URL бакета (R2: Settings > Public Access > Public Development URL, або власний домен)
S3_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
# Тільки для R2: https://<account_id>.r2.cloudflarestorage.com. Для звичайного AWS S3 — лишити порожнім.
S3_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# TikTok — варіант А (рекомендований): Login Kit OAuth, токен виходить сам через /auth/tiktok/login
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://your-railway-domain.up.railway.app/auth/tiktok/callback

# TikTok — варіант Б (fallback): вручну отриманий токен, якщо OAuth ще не налаштований
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# Захищає /auth/tiktok/login від сторонніх — придумай будь-який довгий рядок
ADMIN_SECRET=change-me-to-a-long-random-string
# Підписує Flask-сесію (для OAuth state) — інший довгий випадковий рядок
FLASK_SECRET_KEY=change-me-too

# Instagram — варіант А (рекомендований): Business Login OAuth, токен виходить сам через /auth/instagram/login
# Беремо з Meta App Dashboard: App Dashboard > Instagram > API setup with Instagram login >
# "3. Set up Instagram business login" > "Business login settings" >
# поля "Instagram App ID" і "Instagram app secret".
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://your-railway-domain.up.railway.app/auth/instagram/callback

# Instagram — варіант Б (fallback): вручну отриманий токен, якщо OAuth ще не налаштований
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_account_id

# Логіка публікацій
TIKTOK_DAILY_LIMIT=3
TIKTOK_PUBLISH_TIMES=09:00,13:00,18:00
VIEWS_THRESHOLD=500
INSTAGRAM_PUBLISH_HOUR=10

# Шлях до SQLite-бази. Якщо в Railway підключено persistent Volume — вказати
# шлях усередині нього (напр. /data/socials.db), інакше база зникатиме при
# кожному редеплої. Без env — локальний файл поруч з кодом (для розробки).
DB_PATH=/data/socials.db

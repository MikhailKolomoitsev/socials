# Локальні оверайди для розробки. Скопіюй у .env.local і заповни.
# .env.local не комітяться в git — тут можна зберігати будь-що.

# Локальна БД замість Railway Volume (/data/socials.db)
DB_PATH=./socials_dev.db

# Якщо хочеш тестувати на окремому тест-боті (щоб не конфліктувати з продом):
# TELEGRAM_BOT_TOKEN=<токен тест-бота з @BotFather>
# Якщо залишити порожнім — використовується прод-бот (але тоді Railway треба зупинити!)

# Можна тестувати Drive на окремій папці:
# GOOGLE_DRIVE_FOLDER_ID=<ID тестової папки>
